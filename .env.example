AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-key-id
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_SESSION_TOKEN=your-session-token
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_TEMPERATURE=0.3

GITHUB_TOKEN=your-github-pat

GITEA_URL=http://localhost:3000
GITEA_TOKEN=your-gitea-token
DB_PATH=data/arena.db

# Maximum files per analysis run (1–100, default 50)
MAX_FILES=50

# Lines of context shown above and below each bug location in the code comparison (0–20, default 5)
BUG_CONTEXT_LINES=5

# Which agents to enable — comma-separated keys, or "all" to enable everything.
# Use this to deploy the platform as a focused tool instead of the full suite.
#
# Available keys:
#   bug_analysis, code_design, code_flow, mermaid,
#   requirement, static_analysis, comment_generator, commit_analysis
#
# Preset profiles (copy one of these lines):
#   ENABLED_AGENTS=all                                             # full suite (default)
#   ENABLED_AGENTS=bug_analysis,static_analysis,comment_generator # bug finder
#   ENABLED_AGENTS=code_design,requirement,code_flow,mermaid      # design suite
#   ENABLED_AGENTS=commit_analysis                                 # commit reviewer
ENABLED_AGENTS=all
